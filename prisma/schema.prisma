generator client {
  provider        = "prisma-client"
  previewFeatures = ["postgresqlExtensions"]
  output          = "../src/generated/prisma"
}

datasource db {
  provider   = "postgresql"
}

model User {
  id               String            @id
  name             String
  email            String
  emailVerified    Boolean           @default(false)
  image            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  sessions         Session[]
  accounts         Account[]
  testAttempts     TestAttempt[]
  questionAttempts QuestionAttempt[]
  uploads          UploadBatch[]
  attachments      Attachment[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

enum TestAttemptType {
  MOCK_TEST
  PAST_PAPER
  SECTIONAL_TEST
  CHAPTER_TEST
  PRACTICE_SET
  LOOSE_PRACTICE
}

enum TestAttemptStatus {
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum QuestionResult {
  UNREVIEWED
  CORRECT
  INCORRECT
  PARTIAL
  SKIPPED
}

enum MistakeType {
  CONCEPTUAL
  SILLY
  CALCULATION
  MISREAD
  UNKNOWN
}

enum MistakeStatus {
  NEW
  REVIEWING
  MASTERED
  ARCHIVED
}

enum AttachmentType {
  IMAGE
  PDF
}

enum OcrStatus {
  NOT_STARTED
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AttachmentUploadStatus {
  PENDING
  UPLOADED
  ATTACHED
  FAILED
}

model UploadBatch {
  id            String       @id @default(cuid())
  userId        String
  testAttemptId String?
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  testAttempt   TestAttempt? @relation(fields: [testAttemptId], references: [id], onDelete: Cascade)
  createdAt     DateTime     @default(now())

  attachments Attachment[]
}

enum AnalysisStatus {
  QUEUED
  OCR_PROCESSING
  OCR_COMPLETED
  CHUNKING
  ANALYZING
  COMPLETED
  FAILED
}

model AnalysisRun {
  id            String         @id @default(cuid())
  attachmentId  String
  modelVersion  String
  status        AnalysisStatus @default(QUEUED)
  rawOcr        Json?
  fullText      String?
  pageCount     Int?
  textractJobId String?
  errorMessage  String?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  attachment Attachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)
  chunks     DocumentChunk[]
  mistakes   Mistake[]

  @@index([attachmentId, status])
}

model DocumentChunk {
  id             String  @id @default(cuid())
  attachmentId   String
  analysisRunId  String
  pageStart      Int
  pageEnd        Int
  chunkIndex     Int
  text           String
  sourceBlockIds Json
  confidence     Float?
  needsVision    Boolean @default(false)
  createdAt      DateTime @default(now())

  attachment  Attachment  @relation(fields: [attachmentId], references: [id], onDelete: Cascade)
  analysisRun AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)

  @@unique([analysisRunId, chunkIndex])
  @@index([attachmentId])
}

model Mistake {
  id            String @id @default(cuid())
  analysisRunId String
  type        MistakeType
  description String
  topic       String
  confidence  Float?
  status      MistakeStatus                @default(NEW)
  createdAt DateTime @default(now())

  analysisRun AnalysisRun @relation(fields: [analysisRunId], references: [id], onDelete: Cascade)
}

model Attachment {
  id      String @id @default(cuid())
  batchId String
  userId  String

  storageKey String
  publicUrl  String?
  mimeType   String
  sizeBytes  Int?

  status AttachmentUploadStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  batch UploadBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  analysisRuns AnalysisRun[]
  chunks       DocumentChunk[]
}

model TestAttempt {
  id              String            @id @default(cuid())
  title           String
  examName        String?
  sourceName      String?
  sourceYear      Int?
  type            TestAttemptType   @default(MOCK_TEST)
  status          TestAttemptStatus @default(IN_PROGRESS)
  attemptedAt     DateTime          @default(now())
  durationSeconds Int?
  totalQuestions  Int?
  correctCount    Int?
  incorrectCount  Int?
  skippedCount    Int?
  score           Float?
  maxScore        Float?
  notes           String?
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions       QuestionAttempt[]
  uploads         UploadBatch[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([userId, attemptedAt])
  @@index([userId, type])
  @@map("test_attempt")
}

model QuestionAttempt {
  id             String         @id @default(cuid())
  questionNumber Int?
  questionText   String?
  options        Json?
  correctAnswer  String?
  userAnswer     String?
  result         QuestionResult @default(UNREVIEWED)
  subject        String?
  topic          String?
  subtopic       String?
  difficulty     String?
  marksAwarded   Float?
  maxMarks       Float?
  testAttemptId  String
  testAttempt    TestAttempt    @relation(fields: [testAttemptId], references: [id], onDelete: Cascade)
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([testAttemptId, questionNumber])
  @@index([testAttemptId])
  @@index([userId, result])
  @@index([userId, subject, topic])
  @@map("question_attempt")
}
