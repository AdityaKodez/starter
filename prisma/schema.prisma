
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"

}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]
  playlists      Playlist[]
  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}


enum Status {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
model Playlist {
  id        String   @id @default(cuid())
  title      String 
  thumbnail String?
  sourceUrl String
  ownerName String
  videoCount Int @default(0)

  status   Status  @default(PENDING)
  videos PlaylistVideo[]
  lessons PlaylistLesson[]
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@index([userId])
  @@map("playlist")
}

model PlaylistVideo {
  id          String   @default(cuid()) @id
  youtubeVideoId String
  title       String
  thumbnail   String?
  sourceUrl   String
  duration   Int
  transcription String?
  status     Status @default(PENDING)
  artifacts  Artifact[]
  lessonId   String?
  lesson     PlaylistLesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  playlistId  String
  playlist    Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  notes  PlaylistNotes[]
  transcriptChunks TranscriptChunks[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([playlistId, youtubeVideoId])
  @@index([lessonId])
  @@index([playlistId])
  @@map("playlist_video")
}

model PlaylistLesson {
  id         String   @id @default(cuid())
  title      String
  summary    String
  order      Int
  playlistId String
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  videos     PlaylistVideo[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([playlistId, order])
  @@index([playlistId])
  @@map("playlist_lesson")
}

enum ArtifactType {
   SUMMARY 
   FLASHCARD
   TEST
   MINDMAP
}
model Artifact {
  id          String  @id @default(cuid())
  type        ArtifactType 
  json        Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  playlistVideoId String
  playlistVideo   PlaylistVideo @relation(fields: [playlistVideoId], references: [id], onDelete: Cascade)
  @@index([playlistVideoId])
  @@unique([playlistVideoId, type])
  @@map("artifact")
}

model TranscriptChunks {
  id          String  @id @default(cuid())
  chunkIndex  Int
  text        String
  startTime   Int
  endTime     Int
  tokenCount  Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  playlistVideoId String
  playlistVideo   PlaylistVideo @relation(fields: [playlistVideoId], references: [id], onDelete: Cascade)
  @@index([playlistVideoId])
  @@index([playlistVideoId, startTime])
  @@unique([playlistVideoId, chunkIndex])
  @@map("transcript_chunks")
}

model PlaylistNotes {
  id          String  @id @default(cuid())
  content     String
  timestamp   String
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  playlistvideoId String
  playlistVideo   PlaylistVideo @relation(fields: [playlistvideoId], references: [id], onDelete: Cascade)
  @@index([playlistvideoId])
  @@map("playlist_notes")
}