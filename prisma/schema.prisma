generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String              @id
  name               String
  email              String
  emailVerified      Boolean             @default(false)
  image              String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  sessions           Session[]
  accounts           Account[]
  testAttempts       TestAttempt[]
  questionAttempts   QuestionAttempt[]
  mistakes           Mistake[]
  mistakeAttachments MistakeAttachment[]

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

enum TestAttemptType {
  MOCK_TEST
  PAST_PAPER
  SECTIONAL_TEST
  CHAPTER_TEST
  PRACTICE_SET
  LOOSE_PRACTICE
}

enum TestAttemptStatus {
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum QuestionResult {
  UNREVIEWED
  CORRECT
  INCORRECT
  PARTIAL
  SKIPPED
}

enum MistakeType {
  CONCEPTUAL
  SILLY
  CALCULATION
  MISREAD
  UNKNOWN
}

enum MistakeStatus {
  NEW
  REVIEWING
  MASTERED
  ARCHIVED
}

enum AttachmentType {
  IMAGE
  PDF
}

enum OcrStatus {
  NOT_STARTED
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum AttachmentUploadStatus {
  PENDING
  UPLOADED
  ATTACHED
  FAILED
}

model TestAttempt {
  id              String            @id @default(cuid())
  title           String
  examName        String?
  sourceName      String?
  sourceYear      Int?
  type            TestAttemptType   @default(MOCK_TEST)
  status          TestAttemptStatus @default(IN_PROGRESS)
  attemptedAt     DateTime          @default(now())
  durationSeconds Int?
  totalQuestions  Int?
  correctCount    Int?
  incorrectCount  Int?
  skippedCount    Int?
  score           Float?
  maxScore        Float?
  notes           String?
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions       QuestionAttempt[]
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([userId, attemptedAt])
  @@index([userId, type])
  @@map("test_attempt")
}

model QuestionAttempt {
  id             String         @id @default(cuid())
  questionNumber Int?
  questionText   String?
  options        Json?
  correctAnswer  String?
  userAnswer     String?
  result         QuestionResult @default(UNREVIEWED)
  subject        String?
  topic          String?
  subtopic       String?
  difficulty     String?
  marksAwarded   Float?
  maxMarks       Float?
  testAttemptId  String
  testAttempt    TestAttempt    @relation(fields: [testAttemptId], references: [id], onDelete: Cascade)
  userId         String
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  mistake        Mistake?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([testAttemptId, questionNumber])
  @@index([testAttemptId])
  @@index([userId, result])
  @@index([userId, subject, topic])
  @@map("question_attempt")
}

model Mistake {
  id                String              @id @default(cuid())
  title             String?
  type              MistakeType         @default(UNKNOWN)
  status            MistakeStatus       @default(NEW)
  contextFlags      Json?
  userNote          String?
  rootCause         String?
  fixPlan           String?
  retryDueAt        DateTime?
  lastRetriedAt     DateTime?
  masteredAt        DateTime?
  questionAttemptId String              @unique
  questionAttempt   QuestionAttempt     @relation(fields: [questionAttemptId], references: [id], onDelete: Cascade)
  userId            String
  user              User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachments       MistakeAttachment[]
  retries           MistakeRetry[]
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([userId, status])
  @@index([userId, type])
  @@index([userId, retryDueAt])
  @@map("mistake")
}

model MistakeAttachment {
  id           String                 @id @default(cuid())
  type         AttachmentType
  uploadStatus AttachmentUploadStatus @default(PENDING)
  storageKey   String
  fileName     String?
  mimeType     String
  sizeBytes    Int?
  publicUrl    String?
  ocrStatus    OcrStatus              @default(NOT_STARTED)
  ocrText      String?
  ocrJson      Json?
  ocrError     String?
  mistakeId    String?
  mistake      Mistake?               @relation(fields: [mistakeId], references: [id], onDelete: Cascade)
  userId       String
  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@unique([storageKey])
  @@index([mistakeId])
  @@index([userId, uploadStatus])
  @@index([ocrStatus])
  @@map("mistake_attachment")
}

model MistakeRetry {
  id          String   @id @default(cuid())
  answer      String?
  isCorrect   Boolean
  note        String?
  attemptedAt DateTime @default(now())
  mistakeId   String
  mistake     Mistake  @relation(fields: [mistakeId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([mistakeId, attemptedAt])
  @@map("mistake_retry")
}
